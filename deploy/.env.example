# Copy to deploy/.env on the deployment host and fill in real values.
# Do NOT commit the real .env.

# The published bridge image. Override to pin a SHA for rollback.
BRIDGE_IMAGE=ghcr.io/sacha-builds/hl7-fhir-bridge/bridge:main

BRIDGE_LOG_LEVEL=INFO

# --- FHIR server ---
# For Medplum cloud Developer plan:
#   BRIDGE_FHIR_BASE_URL=https://api.medplum.com/fhir/R4
#   BRIDGE_FHIR_OAUTH_TOKEN_URL=https://api.medplum.com/oauth2/token
#   BRIDGE_FHIR_OAUTH_CLIENT_ID=<from Medplum: Settings → Client Applications>
#   BRIDGE_FHIR_OAUTH_CLIENT_SECRET=<from Medplum>
#
# For a self-hosted HAPI on the same network (no auth):
#   BRIDGE_FHIR_BASE_URL=http://hapi-fhir:8080/fhir
#   (leave OAuth vars blank)
BRIDGE_FHIR_BASE_URL=https://api.medplum.com/fhir/R4
BRIDGE_FHIR_OAUTH_TOKEN_URL=https://api.medplum.com/oauth2/token
BRIDGE_FHIR_OAUTH_CLIENT_ID=
BRIDGE_FHIR_OAUTH_CLIENT_SECRET=

# Background seeder — how often (minutes) the bridge replays a random
# bundled fixture through itself so the deployed inbox stays populated.
# Set to 0 to disable entirely.
BRIDGE_DEMO_REPLAY_INTERVAL_MINUTES=10
