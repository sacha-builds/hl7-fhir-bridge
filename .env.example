# Copy to .env and adjust if needed.

# HAPI FHIR
HAPI_FHIR_VERSION=v7.4.0
HAPI_FHIR_PORT=8080

# Postgres (HAPI backing store)
POSTGRES_USER=hapi
POSTGRES_PASSWORD=hapi
POSTGRES_DB=hapi

# Bridge service
BRIDGE_HTTP_PORT=8000
BRIDGE_MLLP_PORT=2575
BRIDGE_LOG_LEVEL=INFO
FHIR_BASE_URL=http://hapi-fhir:8080/fhir

# Viewer
VIEWER_PORT=5173
VITE_FHIR_BASE_URL=http://localhost:8080/fhir
VITE_BRIDGE_API_URL=http://localhost:8000
